{
  "name": "cms-itsmillertime-dev",
  "version": "3.13.1",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "changeset": "changeset",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "release": "pnpm build && changeset publish",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "version": "changeset version",
    "email:dev": "email dev --port 3001"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@better-auth/passkey": "^1.4.19",
    "@delmaredigital/payload-better-auth": "^0.4.3",
    "@payloadcms/db-postgres": "3.79.1",
    "@payloadcms/email-resend": "3.79.1",
    "@payloadcms/kv-redis": "^3.79.1",
    "@payloadcms/next": "3.79.1",
    "@payloadcms/payload-cloud": "3.79.1",
    "@payloadcms/plugin-cloud-storage": "3.79.1",
    "@payloadcms/plugin-ecommerce": "^3.79.1",
    "@payloadcms/plugin-mcp": "^3.79.1",
    "@payloadcms/plugin-search": "3.79.1",
    "@payloadcms/plugin-sentry": "3.79.1",
    "@payloadcms/plugin-seo": "3.79.1",
    "@payloadcms/richtext-lexical": "3.79.1",
    "@payloadcms/storage-s3": "3.79.1",
    "@payloadcms/ui": "3.79.1",
    "@react-email/components": "1.0.10",
    "@react-email/render": "2.0.4",
    "@sentry/nextjs": "10.45.0",
    "@veiag/payload-cmdk": "^1.1.0",
    "better-auth": "^1.4.19",
    "blurhash": "^2.0.5",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "exifreader": "^4.37.0",
    "fast-xml-parser": "^5.5.7",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "payload": "3.79.1",
    "payload-plugin-webhooks": "^1.1.0",
    "payload-sidebar-plugin": "^1.3.5",
    "pg": "8.20.0",
    "plaiceholder": "^3.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.2",
    "sharp": "0.34.5",
    "slugify": "^1.6.8",
    "word-counting": "^1.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.5",
    "@react-email/preview-server": "5.2.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@typescript/native-preview": "^7.0.0-dev.20260319.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.2.0",
    "prettier": "^3.8.1",
    "react-email": "5.2.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@sentry/cli"
    ]
  }
}
