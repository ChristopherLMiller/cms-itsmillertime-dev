# Medusa control panel (Payload drives Medusa via the Admin API)
# Append these to your CMS .env. Values come from running, in apps/backend:
#   pnpm medusa exec ./src/scripts/setup-digital-commerce.ts
#
# Medusa is the source of truth for products. Payload only stores a
# `medusaProductId` pointer on the gallery image and sends commands here.

# Base URL of the Medusa backend (server-to-server). Local default:
MEDUSA_BACKEND_URL=http://localhost:9000

# Medusa admin dashboard base URL, used for the "Open in Medusa" deep-link in
# the Store panel. Defaults to MEDUSA_BACKEND_URL + /app if unset.
MEDUSA_ADMIN_URL=http://localhost:9000/app

# Secret admin API key (Medusa Admin > Settings > Secret API keys, or printed
# by the setup script the first time it creates the key). Keep this secret.
MEDUSA_ADMIN_API_KEY=

# Public sales channel the products are published to (public storefront).
MEDUSA_SALES_CHANNEL_ID=

# Private sales channel. Images that are not public — visibility "Logged In"
# (AUTHENTICATED) or "By User or Role" (PRIVILEGED) — are listed here instead
# of the public channel. If unset, such images are saved as hidden drafts (never
# exposed publicly). Needs its own publishable key for the gated checkout
# context on the storefront.
MEDUSA_PRIVATE_SALES_CHANNEL_ID=

# Region id (US/USD). Optional; used for reference.
MEDUSA_REGION_ID=

# Shipping profile used for digital products (optional but recommended).
MEDUSA_DIGITAL_SHIPPING_PROFILE_ID=

# Currency for variant prices. Defaults to usd.
MEDUSA_CURRENCY=usd

# Required so the Store panel can resolve a public URL for the gallery image
# (it re-uploads that image into Medusa). Your CMS origin, e.g.:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
